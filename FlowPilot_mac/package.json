    "package:macos": "npm run package:macos:local",
    "package:macos:local": "node scripts/package-macos-local.mjs",
    "package:macos:personal": "node scripts/package-macos-personal.mjs",
    "package:macos:release": "node scripts/package-macos-release.mjs",
    "package:macos:distribution": "node scripts/package-macos-distribution.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
